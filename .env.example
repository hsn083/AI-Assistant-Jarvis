# ── Required API Keys ─────────────────────────────────────────────────────────
GroqAPIKey=
CohereAPIKey=
TavilyAPIKey=
HuggingFaceAPIKey=

# ── Assistant Identity ────────────────────────────────────────────────────────
Username=Sir
Assistantname=Jarvis

# ── Voice & Language ──────────────────────────────────────────────────────────
# Options: en-US  en-GB  ur-PK  hi-IN  etc.
InputLanguage=en-US
AssistantVoice=en-US-GuyNeural
# For Urdu:
# InputLanguage=ur-PK
# AssistantVoice=ur-PK-AsadNeural

# ── Conversation Settings ─────────────────────────────────────────────────────
# True  = Jarvis maintains context across all turns (recommended)
# False = Each query is treated as independent (original behaviour)
ConversationMode=True

# How many past messages to keep in AI context (10 conversations = 20 messages)
HistoryWindow=20
